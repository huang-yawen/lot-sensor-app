PORT=3000
FRONTEND_DIST_PATH=

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=third
# 改数据库的时候使用
DB_CONNECTION_LIMIT=10

#路由器
# MQTT_URL=mqtt://192.168.1.100:1883     
# lsr热点
# MQTT_URL=mqtt://10.97.241.240:1883
# 本地
MQTT_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=lot-sensor-pc-test1
MQTT_USERNAME=
MQTT_PASSWORD=

# ============================================================
# 单设备/多设备模式切换
# ============================================================
# true  - 单设备模式（默认）：整个系统只有一套设备，前端不显示设备选择器
# false - 多设备模式：有多套设备，前端显示设备选择器
# 修改此值后需重启后端服务
# 记得给前端的注释取消或者注释
SINGLE_DEVICE_MODE=true
